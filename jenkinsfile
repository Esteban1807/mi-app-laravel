pipeline {
  agent any

  environment {
    IMAGE = "esteban1807/laravel-app:latest"
  }

  stages {

    stage('Clonar código') {
      steps {
        git 'https://github.com/Esteban1807/mi-app-laravel.git'
      }
    }

    stage('Build Docker') {
      steps {
        sh 'docker build -t $IMAGE .'
      }
    }

    stage('Push Docker') {
      steps {
        withCredentials([string(credentialsId: 'dockerhub-pass', variable: 'PASS')]) {
          sh 'echo $PASS | docker login -u esteban1809 --password-stdin'
          sh 'docker push $IMAGE'
        }
      }
    }

    stage('Deploy Kubernetes') {
      steps {
        sh 'kubectl rollout restart deployment laravel-deployment'
      }
    }

  }
}